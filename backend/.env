# ─────────────────────────────────────────────────────────────
# Configuración ACTIVA del backend UPC ABET LLM
# (este es el .env real, no la plantilla)
# ─────────────────────────────────────────────────────────────
 
# Proveedor: OpenRouter (nube)
# LLM_PROVIDER=local
LLM_PROVIDER=local
OPENROUTER_BASE_URL=http://localhost:11434/v1
OPENROUTER_MODEL=hf.co/unsloth/gemma-4-12b-it-GGUF:UD-Q4_K_XL
OPENROUTER_API_KEY=ollama
# Ventana de contexto (el modelo HF trae 4096 por defecto, demasiado pequeño)
OLLAMA_NUM_CTX=32768
# Tu API key de OpenRouter — RELLENAR con la real
# (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=ollama#'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'
 
# Modelo: Gemma 4 31B (el que usas)
# OPENROUTER_MODEL=gemma4 # google/gemma-4-31b-it
 
# La URL base se autoconfigura a https://openrouter.ai/api/v1 cuando
# LLM_PROVIDER=openrouter, así que no hace falta setearla.
 
# ── Límites (opcionales, descomenta para cambiar) ──
MAX_FILE_SIZE_MB=20
RAG_K=10
RAG_MIN_SCORE=0.10
RAG_MAX_CONTEXT_CHARS=12000
# DEFAULT_CARRERA=cc
# AUDIT_HEAVY_TOKEN_THRESHOLD=100000
 
# ── Para cambiar a LLM local (vLLM/llama.cpp) en el servidor Ubuntu,
#    comenta lo de arriba y descomenta esto: ──
# LLM_PROVIDER=local
# OPENROUTER_API_KEY=EMPTY
# OPENROUTER_BASE_URL=http://localhost:11434/v1
# OPENROUTER_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ
